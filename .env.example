# Copy this to .env for local development (Railway sets these as service variables in production).
# Never commit a real .env file.

DATABASE_URL=postgresql://user:password@host:5432/dbname
FLASK_SECRET_KEY=replace-with-a-long-random-string
ANTHROPIC_API_KEY=sk-ant-your-key-here
FLASK_DEBUG=1
PORT=5000

# Google Sheets case-tracking mirror (optional - app works fine without these,
# Postgres remains the source of truth either way)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...full JSON content as one line..."}
GOOGLE_SHEET_ID=the-id-from-your-sheets-url

# Razorpay - required for the paid tracking tier on health claims (₹199/case)
RAZORPAY_KEY_ID=rzp_live_or_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret_keep_this_private
